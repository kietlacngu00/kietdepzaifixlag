-- HÀM PHÁT TIẾNG VÀ ĐỢI (ĐỂ THANH % CHẠY KHỚP GIỌNG NÓI)
local function PlayAndWait(id)
    if not id or id == "" or id == "0" then return end
    local s = Instance.new("Sound", game.Workspace)
    s.SoundId = "rbxassetid://" .. id
    s.Volume = 5
    s:Play()
    
    local timeout = 0
    -- Đợi nói xong hoặc quá 15 giây thì tự chạy tiếp để tránh bị kẹt
    while s.Playing and timeout < 150 do 
        task.wait(0.1)
        timeout = timeout + 1
    end
    s:Destroy()
end

