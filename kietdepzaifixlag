-- 5. LOGIC CHẠY VÀ FIX LAG NGẦM
task.spawn(function()
    -- Giảm đồ họa để fix lag
    settings().Rendering.QualityLevel = 1
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v:IsA("BasePart") then v.Material = Enum.Material.SmoothPlastic end
    end

    -- Giai đoạn 1: Chạy đến 20%
    task.wait(1)
    TweenService:Create(Bar, TweenInfo.new(0.5), {Size = UDim2.new(0.2, 0, 1, 0)}):Play()
    PercentLabel.Text = "20%"
    PlayAndWait(Sound_20_ID) -- Nghe xong tiếng 1 mới chạy tiếp %
    
    -- Giai đoạn 2: Chạy từ 40% đến 80%
    for i = 2, 4 do
        task.wait(1)
        local p = i * 20
        TweenService:Create(Bar, TweenInfo.new(0.5), {Size = UDim2.new(p/100, 0, 1, 0)}):Play()
        PercentLabel.Text = p .. "%"
    end
    
    -- Mốc 80%: Phát tiếng nói thứ 2
    PlayAndWait(Sound_80_ID)
    
    -- Giai đoạn cuối: 100%
    TweenService:Create(Bar, TweenInfo.new(0.5), {Size = UDim2.new(1, 0, 1, 0)}):Play()
    PercentLabel.Text = "DONE!"
    PercentLabel.TextColor3 = Color3.fromRGB(0, 255, 200)
    
    -- Hiệu ứng nhấp nháy chữ Done
    while true do
        PercentLabel.Visible = not PercentLabel.Visible
        task.wait(0.5)
    end
end)

-- 6. CẬP NHẬT FPS THỰC TẾ
